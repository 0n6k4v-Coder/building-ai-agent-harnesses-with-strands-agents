AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ==========================================
# Provider Selection (ตัวเลือก: thaillm, nvidia)
# ==========================================
ACTIVE_PROVIDER=thaillm

# ==========================================
# 1. ThaiLLM Configuration
# ==========================================
THAILLM_API_KEY=your_thaillm_api_key_here
THAILLM_BASE_URL=https://api.yourprovider.com/v1
THAILLM_MODEL_ID=openthaigpt-thaillm-8b-instruct-v7.2

# ==========================================
# 2. NVIDIA NIM Configuration
# ==========================================
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=nvidia/nemotron-3-ultra-550b-a55b